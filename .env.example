APP_NAME=Axontis-API
APP_ENV=production
APP_KEY=base64:Io6OdpPgPpA2IJutoN1P7SOZlaQ1tB01SGu7Wa+ilVk=
APP_DEBUG=false
APP_URL=https://axontis.net

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=axontis_api
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# ============================================
# MAIL CONFIGURATION - FAILOVER
# ============================================
# Utilise le système de failover avec plusieurs providers
# Si le provider principal échoue, passe automatiquement au suivant
MAIL_MAILER=failover
MAIL_FROM_ADDRESS="noreply@axontis.net"
MAIL_FROM_NAME="${APP_NAME}"

# Configuration SMTP de secours (serveur local)
# Utilisé si aucun provider externe n'est configuré
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

# ============================================
# EMAIL PROVIDERS - Configuration Multi-Mailers avec Failover
# Ordre de priorité : Resend → Mailgun → Brevo
# ============================================

# Resend - Provider principal (3000 emails/mois gratuits)
# https://resend.com/
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mailgun - Backup 1 (5000 emails/mois gratuits pendant 3 mois)
# https://www.mailgun.com/
MAILGUN_DOMAIN=mg.votredomaine.com
MAILGUN_SECRET=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_ENDPOINT=api.eu.mailgun.net

# Brevo (ex-Sendinblue) - Backup 2 (300 emails/jour gratuits)
# https://www.brevo.com/
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_ENCRYPTION=tls
BREVO_SMTP_USERNAME=votre-email@exemple.com
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# SMS PROVIDERS
# ============================================

# Twilio (SMS et WhatsApp)
# https://www.twilio.com/
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+33123456789
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Vonage/Nexmo (Alternative SMS)
# https://www.vonage.com/
VONAGE_KEY=xxxxxxxxx
VONAGE_SECRET=xxxxxxxxxxxxxxxxx
VONAGE_FROM=VotreApp

# ============================================
# MESSAGING PROVIDERS
# ============================================

# Telegram Bot
# https://core.telegram.org/bots
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-123456789

# Slack Webhooks
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
SLACK_NOTIFICATIONS_CHANNEL=#notifications
SLACK_ALERTS_CHANNEL=#alerts

# ============================================
# NOTIFICATION SYSTEM
# ============================================

# Équipe technique pour les alertes critiques
NOTIFICATION_SLACK_WEBHOOK=
NOTIFICATION_TELEGRAM_CHAT_ID=-123456789
NOTIFICATION_TECH_EMAIL=tech@votredomaine.com

# Rate limiting par canal (requêtes par minute)
NOTIFICATION_RATE_LIMIT_EMAIL=60
NOTIFICATION_RATE_LIMIT_SMS=30
NOTIFICATION_RATE_LIMIT_WHATSAPP=30
NOTIFICATION_RATE_LIMIT_TELEGRAM=60

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Configuration Cloudflare R2 - Décommentez et configurez pour utiliser R2
# FILESYSTEM_DISK=r2
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_here
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_key_here
CLOUDFLARE_R2_BUCKET=your_bucket_name
CLOUDFLARE_R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
CLOUDFLARE_R2_URL=https://your_custom_domain.com
# FILESYSTEM_DISK=public

# Docusign
DOCUSIGN_CLIENT_ID=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE_PATH=account-d.docusign.com
# HMAC key from DocuSign Connect settings (for webhook signature validation)
DOCUSIGN_HMAC_KEY=

# Stripe Payment Configuration
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

#Better Stack
SENTRY_LARAVEL_DSN=
